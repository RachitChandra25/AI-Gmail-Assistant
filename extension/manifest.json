{
  "manifest_version": 3,
  "name": "AI Gmail Assistant",
  "version": "1.0",
  "description": "Summarize, translate and generate replies for Gmail using AI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:5000/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["api.js", "ui.js", "content.js"],
      "css": ["styles.css"]
    }
  ]
}
